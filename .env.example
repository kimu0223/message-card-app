# ============================================================
# Google Gemini AI
# ============================================================
GOOGLE_GEMINI_API_KEY=your-gemini-api-key          # サーバーのみ

# ============================================================
# Stripe
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx                      # サーバーのみ
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STANDARD_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_CREDITS_10=price_xxx
STRIPE_PRICE_CREDITS_50=price_xxx

# ============================================================
# 制限値（変更可能）
# ============================================================
FREE_PLAN_MONTHLY_CARDS_LIMIT=5
FREE_PLAN_TEMPLATES_LIMIT=5
AI_MESSAGE_FREE_MONTHLY_LIMIT=10
